---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found — +254">
  <div class="error-page">
    <span class="error-code" aria-hidden="true">404</span>
    <h1 class="error-title">Page not found</h1>
    <p class="error-desc">
      The page you're looking for doesn't exist or has been moved.
      If you followed a link from somewhere, please
      <a href="https://github.com/plus254/plus254/issues">let us know</a>.
    </p>
    <div class="error-actions">
      <a href="/" class="btn-primary">Go home</a>
      <a href="/datasets/" class="btn-secondary">Browse datasets</a>
      <a href="/api-docs/" class="btn-secondary">API docs</a>
    </div>
  </div>
</BaseLayout>

<style>
  .error-page {
    max-width: 36rem;
    margin: var(--space-fluid-xl) auto;
    text-align: center;
  }

  .error-code {
    display: block;
    font-family: var(--font-serif);
    font-size: clamp(4rem, 10vw, 6rem);
    font-weight: var(--font-semibold);
    line-height: 1;
    color: var(--color-green-muted);
    margin-bottom: var(--space-sm);
  }

  .error-title {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: var(--font-semibold);
    color: var(--color-warm-dark);
    margin: 0 0 var(--space-sm);
    line-height: var(--leading-tight);
  }

  .error-desc {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-warm-mid);
    line-height: var(--leading-relaxed);
    margin: 0 0 var(--space-lg);
    max-width: 40ch;
    margin-left: auto;
    margin-right: auto;
  }

  .error-desc a {
    color: var(--color-warm-dark);
    text-decoration: underline;
    text-decoration-color: var(--color-green-muted);
    text-underline-offset: 2px;
  }

  .error-desc a:hover {
    text-decoration-color: var(--color-green);
  }

  .error-actions {
    display: flex;
    gap: var(--space-sm);
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary,
  .btn-secondary {
    min-width: 140px;
    padding: var(--space-sm) var(--space-md);
    border-radius: 0;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    text-decoration: none;
    text-align: center;
    border: 1.5px solid var(--color-green);
    transition: background-color 0.2s var(--ease-out), color 0.2s var(--ease-out);
  }

  .btn-primary {
    background: var(--color-green);
    color: #fff;
  }

  .btn-primary:hover {
    background: transparent;
    color: var(--color-green);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-green);
  }

  .btn-secondary:hover {
    background: var(--color-green);
    color: #fff;
  }
</style>