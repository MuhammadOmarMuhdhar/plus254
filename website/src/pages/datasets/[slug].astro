---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const datasets = await getCollection("dataset");
  return datasets.map((d) => ({
    params: { slug: d.id },
    props: { entry: d },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={`${entry.data.title} — plus254`}>
  <article>
    <h1>{entry.data.title}</h1>
    <div class="meta">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  h1 {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: var(--font-semibold);
    color: var(--color-warm-dark);
    margin: 0 0 var(--space-sm);
  }

  .meta :global(p) {
    color: var(--color-warm-mid);
    line-height: 1.6;
    margin-bottom: var(--space-sm);
    font-size: var(--text-base);
  }

  .meta :global(ul) {
    color: var(--color-warm-mid);
    line-height: 1.6;
    padding-left: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .meta :global(li) {
    margin-bottom: var(--space-2xs);
  }

  .meta :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: rgba(108, 185, 153, 0.15);
    padding: 0.125rem 0.375rem;
  }

  .meta :global(h2) {
    background-color: #6cb999;
    border: 1px solid #1f6f54;
    border-bottom: none;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--color-warm-dark);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: var(--space-lg) 0 0;
    padding: var(--space-xs) var(--space-md);
  }

  .meta :global(h2 ~ table) {
    background-color: #6cb999;
    border: 1px solid #1f6f54;
    border-top: none;
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-warm-dark);
    margin-bottom: var(--space-lg);
  }

  .meta :global(h2 ~ table thead th) {
    text-align: left;
    font-weight: var(--font-semibold);
    color: var(--color-warm-dark);
    padding: var(--space-xs) var(--space-md);
    border-bottom: 2px solid #1f6f54;
  }

  .meta :global(h2 ~ table tbody td) {
    padding: var(--space-sm) var(--space-md);
    border-bottom: 1px solid #1f6f54;
    vertical-align: middle;
  }

  .meta :global(h2 ~ table tbody tr:last-child td) {
    border-bottom: none;
  }
</style>
