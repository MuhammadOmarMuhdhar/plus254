---
import BaseLayout from "../../layouts/BaseLayout.astro";
import DatasetsLayout from "../../components/DatasetsLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const datasets = await getCollection("dataset");
  return datasets.map((d) => ({
    params: { slug: d.id },
    props: { entry: d },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const topicNames: Record<string, string> = {
  economy: "Economy",
  agriculture: "Agriculture",
  governance: "Governance",
};
const topicLabel = topicNames[entry.data.topic] ?? entry.data.topic;
---

<BaseLayout title={`${entry.data.title} — plus254`}>
  <DatasetsLayout activeSlug={entry.id}>
    <header class="page-heading">
      <p class="breadcrumb">{topicLabel}</p>
      <h1>{entry.data.title}</h1>
      <p class="subtitle">{entry.data.description}</p>
    </header>

    <div class="meta-tags">
      <span class="meta-tag">{entry.data.source}</span>
      <span class="meta-tag"><code>{entry.data.endpoint}</code></span>
      <span class="meta-tag">{entry.data.rows.toLocaleString()} rows</span>
      {entry.data.sourceUrl && <span class="meta-tag meta-tag--url">{entry.data.sourceUrl}</span>}
    </div>

    <div class="meta">
      <Content />
    </div>
  </DatasetsLayout>
</BaseLayout>

<style>
  .page-heading {
    margin-bottom: var(--space-md);
  }

  .breadcrumb {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    color: var(--color-warm-light);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 var(--space-2xs);
  }

  .page-heading h1 {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: var(--font-semibold);
    color: var(--color-warm-dark);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-xs);
  }

  .subtitle {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-warm-mid);
    line-height: var(--leading-relaxed);
    margin: 0;
    max-width: 65ch;
  }

  .meta-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  .meta-tag {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--font-medium);
    color: var(--color-warm-dark);
    background: var(--color-green-bg);
    border: 1px solid rgba(31, 111, 84, 0.35);
    padding: var(--space-2xs) var(--space-xs);
    line-height: var(--leading-normal);
    overflow-wrap: break-word;
    word-wrap: break-word;
    max-width: 100%;
  }

  .meta-tag code {
    font-family: var(--font-mono);
    font-size: 0.9em;
  }

  .meta-tag--url {
    max-width: 100%;
    word-break: break-all;
  }

  .meta :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: rgba(108, 185, 153, 0.15);
    padding: 0.125rem 0.375rem;
    color: var(--color-warm-dark);
  }

  .meta :global(h2) {
    background-color: var(--color-green-bg);
    border: 1px solid var(--color-green);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--color-warm-dark);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: var(--space-lg) 0 0;
    padding: var(--space-xs) var(--space-md);
  }

  .meta :global(h2:first-child) {
    margin-top: 0;
  }

  .meta {
    max-width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .meta :global(h2 ~ table) {
    background-color: var(--color-green-bg);
    border: 1px solid var(--color-green);
    border-top: none;
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-warm-dark);
    margin-bottom: var(--space-lg);
    min-width: 500px;
  }

  .meta :global(h2 ~ table thead th) {
    text-align: left;
    font-weight: var(--font-semibold);
    color: var(--color-warm-dark);
    padding: var(--space-xs) var(--space-sm);
    border-bottom: 2px solid var(--color-green);
    white-space: nowrap;
  }

  .meta :global(h2 ~ table tbody td) {
    padding: var(--space-xs) var(--space-sm);
    border-bottom: 1px solid var(--color-green);
    vertical-align: middle;
    word-break: break-word;
  }

  .meta :global(h2 ~ table tbody tr:last-child td) {
    border-bottom: none;
  }

  .meta :global(.code-block) {
    background: var(--color-green-bg);
    border: 1px solid rgba(31, 111, 84, 0.35);
    padding: var(--space-md);
    overflow-x: auto;
    overflow-y: hidden;
    margin: 0 0 var(--space-lg);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    tab-size: 2;
    max-width: 100%;
    word-wrap: normal;
    white-space: pre;
  }

  .meta :global(.code-block code) {
    font-family: var(--font-mono);
    color: var(--color-warm-dark);
  }

  .meta :global(.dataset-table td code) {
    word-break: break-word;
  }

  .meta :global(.dataset-table td:first-child) {
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .meta :global(.dataset-table thead) {
      display: none;
    }

    .meta :global(.dataset-table) {
      min-width: 0;
    }

    .meta :global(.dataset-table tbody tr) {
      display: block;
      padding: 0;
      border-bottom: 1px solid #1f6f54;
    }

    .meta :global(.dataset-table tbody tr:last-child) {
      border-bottom: none;
    }

    .meta :global(.dataset-table td) {
      display: flex;
      flex-direction: column;
      padding: var(--space-2xs) var(--space-md);
      border: none;
    }

    .meta :global(.dataset-table td:first-child) {
      padding-top: var(--space-sm);
    }

    .meta :global(.dataset-table td:last-child) {
      padding-bottom: var(--space-sm);
    }

    .meta :global(.dataset-table td::before) {
      content: attr(data-label);
      display: block;
      font-family: var(--font-sans);
      font-size: var(--text-xs);
      font-weight: var(--font-semibold);
      color: var(--color-warm-dark);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin-bottom: 0.125rem;
    }
  }
</style>
