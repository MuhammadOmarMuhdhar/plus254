---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const datasets = await getCollection("dataset");
const grouped = datasets.reduce(
  (acc, d) => {
    (acc[d.data.category] ??= []).push(d);
    return acc;
  },
  {} as Record<string, typeof datasets>,
);
const categoryNames: Record<string, string> = {
  centralbank: "Central Bank of Kenya",
  teaboard: "Tea Board of Kenya",
};
---

<BaseLayout title="Datasets — plus254">
  <h1>Datasets</h1>
  <p>Browse the full catalog of datasets below. Each entry includes column descriptions, sample data, and API endpoint details — click a dataset name to explore.</p>

  {Object.entries(grouped).map(([category, items]) => (
    <div class="dataset-panel">
      <h4>{categoryNames[category] || category}</h4>
      <table class="dataset-table">
        <thead>
          <tr>
            <th>Dataset</th>
            <th>Description</th>
            <th class="num">Rows</th>
            <th class="num">Endpoint</th>
          </tr>
        </thead>
        <tbody>
          {items.map((d) => (
            <tr>
              <td><a href={`/datasets/${d.id}/`}>{d.data.title}</a></td>
              <td>{d.data.description}</td>
              <td class="num">{d.data.rows}</td>
              <td class="num"><code>{d.data.endpoint}</code></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  ))}
</BaseLayout>

<style>
  h1 {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: var(--font-semibold);
    color: var(--color-warm-dark);
    margin: 0 0 var(--space-sm);
  }

  p {
    color: var(--color-warm-light);
    margin-bottom: var(--space-lg);
  }

  .dataset-panel {
    background-color: #6cb999;
    border: 1px solid #1f6f54;
    font-family: var(--font-sans);
    margin-bottom: var(--space-lg);
  }

  .dataset-panel h4 {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--color-warm-dark);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 0;
    padding: var(--space-xs) var(--space-md);
    border-bottom: 1px solid #1f6f54;
  }

  .dataset-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-warm-dark);
  }

  .dataset-table thead th {
    text-align: left;
    font-weight: var(--font-semibold);
    color: var(--color-warm-dark);
    padding: var(--space-xs) var(--space-md);
    border-bottom: 2px solid #1f6f54;
  }

  .dataset-table thead th.num {
    text-align: right;
  }

  .dataset-table tbody td {
    padding: var(--space-sm) var(--space-md);
    border-bottom: 1px solid #1f6f54;
    vertical-align: middle;
  }

  .dataset-table tbody td.num {
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  .dataset-table a {
    color: var(--color-warm-dark);
    text-decoration: underline;
    text-decoration-color: rgba(31, 111, 84, 0.4);
    text-underline-offset: 2px;
    transition: text-decoration-color 0.15s var(--ease-out);
  }

  .dataset-table a:hover {
    text-decoration-color: #1f6f54;
  }

  .dataset-table code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: rgba(31, 111, 84, 0.1);
    padding: 0.125rem 0.375rem;
  }
</style>
