---
import "../styles/tokens.css";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

export interface Props {
  title?: string;
  description?: string;
}

const { title = "plus254", description = "A unified API for Kenyan official statistics" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,100..1000&family=Newsreader:opsz,wght@6..72,200..800&display=swap"
      as="style"
      crossorigin
    />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,100..1000&family=Newsreader:opsz,wght@6..72,200..800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header />
    <div class="page">
      <slot />
    </div>
    <Footer />
  </body>
</html>

<style>
  .page {
    max-width: 960px;
    margin: 0 auto;
    padding: var(--space-lg) var(--space-md);
  }
</style>
