---
export interface Props {
  activeSection: "quickstart" | "endpoints" | "datasets" | "response" | "clients" | "errors";
}

const { activeSection } = Astro.props;

const navItems = [
  { id: "quickstart", label: "Quickstart", href: "/api-docs/" },
  { id: "endpoints", label: "Endpoints", href: "/api-docs/endpoints/" },
  { id: "datasets", label: "Datasets", href: "/api-docs/datasets/" },
  { id: "response", label: "Response Format", href: "/api-docs/response-format/" },
  { id: "clients", label: "Client Libraries", href: "/api-docs/clients/" },
  { id: "errors", label: "Error Handling", href: "/api-docs/errors/" },
];

const activeLabel = navItems.find((item) => item.id === activeSection)?.label ?? "";
---

<div class="docs-layout">
  <aside class="sidebar">
    <nav class="sidebar-nav">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={["sidebar-link", { active: activeSection === item.id }]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <details class="sidebar-mobile">
      <summary class="sidebar-mobile-summary">
        <span class="sidebar-mobile-label">{activeLabel}</span>
        <svg class="sidebar-mobile-chevron" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="4 6 8 10 12 6" />
        </svg>
      </summary>
      <div class="sidebar-mobile-nav">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class:list={["sidebar-mobile-link", { active: activeSection === item.id }]}
            >
              {item.label}
            </a>
          ))
        }
      </div>
    </details>
  </aside>

  <main class="docs-main">
    <header class="docs-header">
      <h1 class="docs-title">API Reference</h1>
    </header>

    <slot />
  </main>
</div>

<style is:global>
  .docs-layout {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
  }

  .sidebar {
    width: 185px;
    flex-shrink: 0;
    position: sticky;
    top: var(--space-lg);
    padding-top: var(--space-sm);
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .sidebar-link {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-warm-light);
    text-decoration: none;
    padding: var(--space-xs) var(--space-sm);
    border-left: 2px solid transparent;
    transition: color 0.15s var(--ease-out), border-color 0.15s var(--ease-out);
  }

  .sidebar-link:hover {
    color: var(--color-warm-dark);
    border-left-color: rgba(31, 111, 84, 0.3);
  }

  .sidebar-link.active {
    color: #1f6f54;
    border-left-color: #1f6f54;
    font-weight: var(--font-semibold);
  }

  .sidebar-link:focus-visible {
    outline: 2px solid #1f6f54;
    outline-offset: 2px;
  }

  .docs-main {
    flex: 1;
    min-width: 0;
  }

  .docs-header {
    margin-bottom: 0;
  }

  .docs-title {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: var(--font-semibold);
    color: var(--color-warm-dark);
    margin: 0 0 var(--space-md);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
  }

  .docs-intro {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-warm-mid);
    line-height: var(--leading-relaxed);
    margin: 0 0 var(--space-sm);
    max-width: 65ch;
  }

  .docs-intro:last-child {
    margin-bottom: 0;
  }

  .intro-text {
    margin-bottom: var(--space-xl);
  }

  .section {
    margin-bottom: var(--space-fluid-xl);
  }

  .section--empty {
    margin-bottom: var(--space-md);
  }

  .section-eyebrow {
    font-family: var(--font-sans);
    font-size: var(--text-md);
    font-weight: var(--font-semibold);
    color: var(--color-warm-light);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 var(--space-md);
  }

  .step-text {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-warm-mid);
    line-height: var(--leading-relaxed);
    margin: 0 0 var(--space-sm);
    max-width: 65ch;
  }

  .code-block {
    background: #6cb999;
    border: 1px solid rgba(31, 111, 84, 0.35);
    padding: var(--space-md);
    overflow-x: auto;
    margin: 0 0 var(--space-md);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    tab-size: 2;
  }

  .code-block code {
    font-family: var(--font-mono);
    color: var(--color-warm-dark);
  }

  .endpoint-heading {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    color: var(--color-warm-dark);
    margin: var(--space-2md) 0 var(--space-2xs);
    line-height: var(--leading-snug);
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .endpoint-heading:first-child {
    margin-top: 0;
  }

  .endpoint-heading code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: rgba(31, 111, 84, 0.15);
    padding: 0.125rem 0.375rem;
    color: var(--color-warm-dark);
  }

  .method {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: var(--font-semibold);
    letter-spacing: 0.04em;
    padding: 0.125rem 0.375rem;
    border-radius: 0;
  }

  .method.get {
    background: rgba(31, 111, 84, 0.15);
    color: #1f6f54;
    padding: 0.125rem 0.5rem;
  }

  .endpoint-desc {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-warm-mid);
    line-height: var(--leading-relaxed);
    margin: 0 0 var(--space-md);
    max-width: 65ch;
  }

  .next-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: #1f6f54;
    text-decoration: none;
    padding: var(--space-sm) var(--space-md);
    border: 1.5px solid #1f6f54;
    transition: background-color 0.15s var(--ease-out), color 0.15s var(--ease-out);
  }

  .next-btn:hover {
    background: #1f6f54;
    color: #fff;
  }

  .next-btn:active {
    opacity: 0.8;
  }

  .next-btn:focus-visible {
    outline: 2px solid #1f6f54;
    outline-offset: 2px;
  }

  .dataset-panel {
    background-color: #6cb999;
    border: 1px solid #1f6f54;
    font-family: var(--font-sans);
    margin-bottom: var(--space-lg);
  }

  .dataset-panel h4 {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--color-warm-dark);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 0;
    padding: var(--space-xs) var(--space-md);
    border-bottom: 1px solid #1f6f54;
  }

  .dataset-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-warm-dark);
  }

  .dataset-table thead th {
    text-align: left;
    font-weight: var(--font-semibold);
    color: var(--color-warm-dark);
    padding: var(--space-xs) var(--space-md);
    border-bottom: 2px solid #1f6f54;
  }

  .dataset-table tbody td {
    padding: var(--space-sm) var(--space-md);
    border-bottom: 1px solid #1f6f54;
    vertical-align: middle;
  }

  .dataset-table tbody tr:last-child td {
    border-bottom: none;
  }

  .dataset-table td code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: rgba(31, 111, 84, 0.1);
    padding: 0.125rem 0.375rem;
  }

  .endpoint-label {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-warm-light);
    margin: 0 0 var(--space-xs);
  }

  .param-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    margin: 0 0 var(--space-md);
  }

  .param-table th {
    text-align: left;
    font-weight: var(--font-semibold);
    color: var(--color-warm-dark);
    padding: var(--space-sm) var(--space-md);
    border-bottom: 2px solid rgba(31, 111, 84, 0.3);
  }

  .param-table td {
    padding: var(--space-sm) var(--space-md);
    color: var(--color-warm-mid);
    border-bottom: 1px solid rgba(31, 111, 84, 0.15);
    line-height: var(--leading-normal);
  }

  .param-table tbody tr:nth-child(even) {
    background: rgba(31, 111, 84, 0.04);
  }

  .param-table td code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: rgba(31, 111, 84, 0.12);
    padding: 0.0625rem 0.25rem;
    color: var(--color-warm-dark);
  }

  .param-table tr:last-child td {
    border-bottom: none;
  }

  @media (max-width: 900px) {
    .docs-layout {
      flex-direction: column;
      gap: var(--space-lg);
    }
    .sidebar {
      position: static;
      width: 100%;
      padding-top: 0;
    }
    .sidebar-nav {
      flex-direction: row;
      overflow-x: auto;
      gap: 0.125rem;
      padding: 0 0 var(--space-sm) 0;
      border-bottom: 1px solid rgba(31, 111, 84, 0.15);
    }
    .sidebar-link {
      white-space: nowrap;
      border-left: none;
      border-bottom: 2px solid transparent;
    }
    .sidebar-link:hover {
      border-left-color: transparent;
      border-bottom-color: rgba(31, 111, 84, 0.3);
    }
    .sidebar-link.active {
      border-left-color: transparent;
      border-bottom-color: #1f6f54;
    }
  }

  .sidebar-mobile {
    display: none;
  }

  .sidebar-mobile-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-sm) var(--space-md);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--color-warm-dark);
    cursor: pointer;
    min-height: 44px;
    list-style: none;
    border: 1px solid #1f6f54;
    background: #6cb999;
  }

  .sidebar-mobile-summary::-webkit-details-marker {
    display: none;
  }

  .sidebar-mobile-summary::marker {
    display: none;
  }

  .sidebar-mobile-summary:focus-visible {
    outline: 2px solid #1f6f54;
    outline-offset: -2px;
  }

  .sidebar-mobile-chevron {
    transition: transform 0.2s var(--ease-out);
    color: var(--color-warm-dark);
  }

  .sidebar-mobile[open] .sidebar-mobile-chevron {
    transform: rotate(180deg);
  }

  .sidebar-mobile-nav {
    display: flex;
    flex-direction: column;
    border: 1px solid #1f6f54;
    border-top: none;
    background: #6cb999;
  }

  .sidebar-mobile-link {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-warm-dark);
    text-decoration: none;
    padding: var(--space-sm) var(--space-md);
    border-left: 2px solid transparent;
    min-height: 44px;
    display: flex;
    align-items: center;
    transition: background-color 0.15s var(--ease-out), color 0.15s var(--ease-out);
  }

  .sidebar-mobile-link:hover {
    color: var(--color-warm-dark);
    background: rgba(31, 111, 84, 0.08);
  }

  .sidebar-mobile-link.active {
    color: var(--color-warm-dark);
    border-left-color: var(--color-warm-dark);
    font-weight: var(--font-semibold);
    background: rgba(31, 111, 84, 0.12);
  }

  .sidebar-mobile-link:focus-visible {
    outline: 2px solid #1f6f54;
    outline-offset: -2px;
  }

  @media (max-width: 480px) {
    .sidebar-nav {
      display: none;
    }

    .sidebar {
      position: static;
      width: 100%;
      padding-top: 0;
    }

    .sidebar-mobile {
      display: block;
    }

    .code-block {
      overflow-x: visible;
      white-space: pre-wrap;
      word-break: break-word;
      overflow-wrap: break-word;
      font-size: var(--text-xs);
    }

    .code-block code {
      white-space: pre-wrap;
      word-break: break-word;
    }

    .docs-intro,
    .step-text,
    .endpoint-desc,
    .endpoint-label {
      word-break: break-word;
      overflow-wrap: break-word;
    }

    .param-table thead,
    .dataset-table thead {
      display: none;
    }

    .param-table tbody tr,
    .dataset-table tbody tr {
      display: block;
      padding: var(--space-sm) var(--space-md);
      border-bottom: 1px solid rgba(31, 111, 84, 0.15);
    }

    .param-table tbody tr:last-child,
    .dataset-table tbody tr:last-child {
      border-bottom: none;
    }

    .param-table tbody tr:nth-child(even),
    .dataset-table tbody tr:nth-child(even) {
      background: transparent;
    }

    .param-table td,
    .dataset-table td {
      display: flex;
      flex-direction: column;
      padding: var(--space-2xs) 0;
      border: none;
      background: transparent;
    }

    .param-table td::before,
    .dataset-table td::before {
      content: attr(data-label);
      display: block;
      font-family: var(--font-sans);
      font-size: var(--text-xs);
      font-weight: var(--font-semibold);
      color: var(--color-warm-light);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin-bottom: 0.125rem;
    }

    .dataset-panel .dataset-table tbody tr {
      padding: var(--space-xs) var(--space-md);
    }
  }
</style>
