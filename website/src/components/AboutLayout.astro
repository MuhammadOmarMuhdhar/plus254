---
export interface Props {
  activeSection: "mission" | "data-processing" | "support";
}

const { activeSection } = Astro.props;

const navItems = [
  { id: "mission", label: "Mission", href: "#mission" },
  { id: "data-processing", label: "Data Processing", href: "#data-processing-decisions" },
  { id: "support", label: "Support & Contributions", href: "#support" },
];

const activeLabel = navItems.find((item) => item.id === activeSection)?.label ?? "";
---

<div class="about-layout">
  <aside class="about-sidebar">
    <nav class="about-sidebar-nav">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={["about-sidebar-link", { active: activeSection === item.id }]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <details class="about-sidebar-mobile">
      <summary class="about-sidebar-mobile-summary">
        <span class="about-sidebar-mobile-label">{activeLabel}</span>
        <svg class="about-sidebar-mobile-chevron" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="4 6 8 10 12 6" />
        </svg>
      </summary>
      <div class="about-sidebar-mobile-nav">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class:list={["about-sidebar-mobile-link", { active: activeSection === item.id }]}
            >
              {item.label}
            </a>
          ))
        }
      </div>
    </details>
  </aside>

  <main class="about-main">
    <slot />
  </main>
</div>

<style>
  .about-layout {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
    max-width: 960px;
    margin: 0 auto;
  }

  .about-sidebar {
    width: 185px;
    flex-shrink: 0;
    position: sticky;
    top: var(--space-lg);
    padding-top: var(--space-sm);
  }

  .about-sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .about-sidebar-link {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-warm-light);
    text-decoration: none;
    padding: var(--space-xs) var(--space-sm);
    border-left: 2px solid transparent;
    transition: color 0.15s var(--ease-out), border-color 0.15s var(--ease-out);
  }

  .about-sidebar-link:hover {
    color: var(--color-warm-dark);
    border-left-color: rgba(31, 111, 84, 0.3);
  }

  .about-sidebar-link.active {
    color: #1f6f54;
    border-left-color: #1f6f54;
    font-weight: var(--font-semibold);
  }

  .about-sidebar-link:focus-visible {
    outline: 2px solid #1f6f54;
    outline-offset: 2px;
  }

  .about-main {
    flex: 1;
    min-width: 0;
  }

  .about-sidebar-mobile {
    display: none;
  }

  .about-sidebar-mobile-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-sm) var(--space-md);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--color-warm-dark);
    cursor: pointer;
    min-height: 44px;
    list-style: none;
    border: 1px solid #1f6f54;
    background: #6cb999;
  }

  .about-sidebar-mobile-summary::-webkit-details-marker {
    display: none;
  }

  .about-sidebar-mobile-summary::marker {
    display: none;
  }

  .about-sidebar-mobile-summary:focus-visible {
    outline: 2px solid #1f6f54;
    outline-offset: -2px;
  }

  .about-sidebar-mobile-chevron {
    transition: transform 0.2s var(--ease-out);
    color: var(--color-warm-dark);
  }

  .about-sidebar-mobile[open] .about-sidebar-mobile-chevron {
    transform: rotate(180deg);
  }

  .about-sidebar-mobile-nav {
    display: flex;
    flex-direction: column;
    border: 1px solid #1f6f54;
    border-top: none;
    background: #6cb999;
  }

  .about-sidebar-mobile-link {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-warm-dark);
    text-decoration: none;
    padding: var(--space-sm) var(--space-md);
    border-left: 2px solid transparent;
    min-height: 44px;
    display: flex;
    align-items: center;
    transition: background-color 0.15s var(--ease-out), color 0.15s var(--ease-out);
  }

  .about-sidebar-mobile-link:hover {
    color: var(--color-warm-dark);
    background: rgba(31, 111, 84, 0.08);
  }

  .about-sidebar-mobile-link.active {
    color: var(--color-warm-dark);
    border-left-color: var(--color-warm-dark);
    font-weight: var(--font-semibold);
    background: rgba(31, 111, 84, 0.12);
  }

  .about-sidebar-mobile-link:focus-visible {
    outline: 2px solid #1f6f54;
    outline-offset: -2px;
  }

  @media (max-width: 900px) {
    .about-layout {
      flex-direction: column;
      gap: var(--space-lg);
    }
    .about-sidebar {
      position: static;
      width: 100%;
      padding-top: 0;
    }
    .about-sidebar-nav {
      flex-direction: row;
      overflow-x: auto;
      gap: 0.125rem;
      padding: 0 0 var(--space-sm) 0;
      border-bottom: 1px solid rgba(31, 111, 84, 0.15);
    }
    .about-sidebar-link {
      white-space: nowrap;
      border-left: none;
      border-bottom: 2px solid transparent;
    }
    .about-sidebar-link:hover {
      border-left-color: transparent;
      border-bottom-color: rgba(31, 111, 84, 0.3);
    }
    .about-sidebar-link.active {
      border-left-color: transparent;
      border-bottom-color: #1f6f54;
    }
  }

  @media (max-width: 480px) {
    .about-sidebar-nav {
      display: none;
    }

    .about-sidebar {
      position: static;
      width: 100%;
      padding-top: 0;
    }

    .about-sidebar-mobile {
      display: block;
    }
  }
</style>

<script>
  const navMap = {
    'mission': 'Mission',
    'data-processing-decisions': 'Data Processing',
    'support': 'Support & Contributions'
  };

  const sectionIds = Object.keys(navMap);
  const links = document.querySelectorAll('.about-sidebar-link, .about-sidebar-mobile-link');
  const label = document.querySelector('.about-sidebar-mobile-label');

  function updateActive(id) {
    links.forEach(link => {
      link.classList.toggle('active', link.getAttribute('href') === '#' + id);
    });
    if (label && navMap[id]) {
      label.textContent = navMap[id];
    }
  }

  const observer = new IntersectionObserver((entries) => {
    for (const entry of entries) {
      if (entry.isIntersecting) {
        updateActive(entry.target.id);
      }
    }
  }, {
    rootMargin: '-80px 0px -75% 0px'
  });

  for (const id of sectionIds) {
    const el = document.getElementById(id);
    if (el) observer.observe(el);
  }
</script>
